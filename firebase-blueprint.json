{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Base user information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["standard"] },
        "connectedMembers": { 
          "type": "array",
          "description": "List of user IDs that this user is tracking."
        },
        "settings": { "type": "object" }
      },
      "required": ["displayName", "email"]
    },
    "Medication": {
      "title": "Medication",
      "description": "A scheduled medication for a specific user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dose": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Taken", "Upcoming", "Missed"] },
        "days": { "type": "array" },
        "referenceImageUrl": { "type": "string", "description": "Base64 reference photo of the pill." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "dose", "time", "status"]
    },
    "Connection": {
      "title": "Family Connection",
      "description": "A relational link between two family members.",
      "type": "object",
      "properties": {
        "uidA": { "type": "string" },
        "uidB": { "type": "string" },
        "typeA": { "type": "string", "description": "Role of user A in relation to B (e.g., Mom)" },
        "typeB": { "type": "string", "description": "Role of user B in relation to A (e.g., Son)" },
        "status": { "type": "string", "enum": ["pending", "accepted"] }
      },
      "required": ["uidA", "uidB", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles containing tracking information."
    },
    "/users/{userId}/meds/{medId}": {
      "schema": "Medication",
      "description": "Medication schedule for the user."
    },
    "/connections/{connId}": {
      "schema": "Connection",
      "description": "Global family links to determine access to others' dashboards."
    }
  }
}
