{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["api/**/*", "server/models/**/*"]
}
