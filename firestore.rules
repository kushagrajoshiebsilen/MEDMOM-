rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Relational Check: Am I connected to this user?
    function hasConnection(otherUid) {
      let myId = request.auth.uid;
      // We assume connection docs have 'uidA' and 'uidB' and 'status' == 'accepted'
      // To keep it simple for rules (avoiding unbounded queries), we check a specific connection ID format
      // Or we can use a query if it's for 'list'
      return exists(/databases/$(database)/documents/connections/$(myId + '_' + otherUid)) ||
             exists(/databases/$(database)/documents/connections/$(otherUid + '_' + myId));
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || hasConnection(userId));
      allow list: if isVerified() && isOwner(userId); // Prevent blanket reads
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'connectedMembers', 'settings'])
      );

      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               (data.get('role', 'standard') == 'standard');
      }
    }

    // --- Medications Collection ---
    match /users/{userId}/meds/{medId} {
      allow get: if isSignedIn() && (isOwner(userId) || hasConnection(userId));
      allow list: if isSignedIn() && (isOwner(userId) || hasConnection(userId));
      
      allow create: if isOwner(userId) && isValidMed(incoming()) && isValidId(medId);
      allow update: if isOwner(userId) && isValidMed(incoming()) && (
        // Action: Mark Taken
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'Taken') ||
        // Action: Edit Med
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'dose', 'time', 'days', 'updatedAt']))
      );
      allow delete: if isOwner(userId);

      function isValidMed(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.dose is string && data.dose.size() <= 100 &&
               data.time is string && data.time.matches('^[0-9]{1,2}:[0-9]{2} [AP]M$') &&
               data.status in ['Pending', 'Taken', 'Upcoming', 'Missed'] &&
               (data.get('referenceImageUrl', '') is string && data.get('referenceImageUrl', '').size() <= 2000000); // Allow up to 2MB base64
      }
    }

    // --- Connections Collection ---
    match /connections/{connId} {
      allow get, list: if isSignedIn() && (isOwner(existing().uidA) || isOwner(existing().uidB));
      
      allow create: if isSignedIn() && 
                    (isOwner(incoming().uidA) || isOwner(incoming().uidB)) && 
                    isValidConnection(incoming()) && 
                    isValidId(connId);
                    
      allow update: if isSignedIn() && 
                    (isOwner(existing().uidA) || isOwner(existing().uidB)) &&
                    incoming().uidA == existing().uidA &&
                    incoming().uidB == existing().uidB &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'typeA', 'typeB']);

      function isValidConnection(data) {
        return data.uidA is string && data.uidB is string &&
               data.status in ['pending', 'accepted'];
      }
    }
  }
}
